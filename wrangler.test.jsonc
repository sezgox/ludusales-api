{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ludusales-api-test",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-10",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ludusales-backoffice-test",
      "database_id": "test-db",
      "migrations_dir": "migrations"
    }
  ],
  "vars": {
    "CONTACT_TO_EMAIL": "juanma@ludusales.com",
    "RESEND_FROM_EMAIL": "Ludus Sales <juanma@ludusales.com>",
    "FRONTEND_ORIGINS": "https://ludusales.com,https://www.ludusales.com,http://localhost:4200",
    "FRONTEND_BACKOFFICE_URL": "https://ludusales.com/backoffice",
    "MICROSOFT_REDIRECT_URI": "https://api.ludusales.com/auth/microsoft/callback",
    "MICROSOFT_TENANT": "consumers",
    "OWNER_MICROSOFT_EMAIL": "juan.mateoc@outlook.com",
    "OWNER_PUBLIC_EMAIL": "juanma@ludusales.com"
  }
}
